{
  "author": "Chavithra Parana <chavithra@gmail.com>",
  "dependencies": {
    "glob": "^13.0.6",
    "neverthrow": "^8.2.0",
    "typebox": "^1.1.39",
    "uuid": "^13.0.0"
  },
  "description": "",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/benchmark": "^2.1.5",
    "@types/node": "^25.8.0",
    "benchmark": "^2.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./control-flow": {
      "types": "./dist/control-flow/index.d.ts",
      "default": "./dist/control-flow/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./operation": {
      "types": "./dist/operation/index.d.ts",
      "default": "./dist/operation/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [],
  "license": "BSD-3-Clause",
  "name": "rawbox-plugin",
  "scripts": {
    "build": "tsc",
    "demo-benchmark": "npm run build && node --max-old-space-size=8192 dist/demos/demo-benchmark.js",
    "demo-definition": "npx tsx src/demos/demo-definition.js",
    "demo-load": "npm run build && node --max-old-space-size=8192 dist/demos/demo-load.js",
    "demo-registry": "npm run build && node dist/demos/demo-registry.js",
    "generate-benchmark": "npm run build && node dist/generate-benchmark-files.js",
    "lint": "eslint .",
    "start": "npm run build && node dist/index.js",
    "test": "vitest run tests",
    "test:coverage": "vitest run tests --coverage",
    "test:watch": "vitest tests",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "version": "1.0.0"
}
